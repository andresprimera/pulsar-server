# App
NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/pulsar

# Encryption (required in production for credential encryption at rest)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_ENCRYPTION_KEY=

# Seeding (dev: default on; prod/test: set SEED_DB=true to run)
# SEED_DB=false

# LLM (fallback when channel llmConfig uses REPLACE_ME or is missing)
OPENAI_API_KEY=

# Optional: semantic routing for multi-agent disambiguation
# ENABLE_SEMANTIC_ROUTING=false

# --- Channel credential fallback (auth only; routing IDs always from DB) ---
# Used when channel config has no credentials in DB. See docs/env-channel-credentials.md
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_DIALOG360_API_KEY=
INSTAGRAM_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=

# --- WhatsApp / Meta ---
WHATSAPP_API_HOST=https://graph.facebook.com
WHATSAPP_API_VERSION=v18.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=dev

# --- WhatsApp Dialog360 ---
DIALOG360_API_HOST=https://waba.360dialog.io/v1

# --- Instagram ---
INSTAGRAM_API_HOST=https://graph.facebook.com
INSTAGRAM_API_VERSION=v24.0
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=dev
INSTAGRAM_APP_SECRET=

# --- TikTok ---
TIKTOK_API_BASE_URL=https://business-api.tiktok.com/open_api/v1.2
